# 팡슐랭 운영 환경 변수 템플릿
#
# 사용법: 이 파일을 복사해 EC2 의 /opt/pangchelin/.env.production 으로 두고
#        실제 값을 채운다. 권한 660, 소유자 ec2-user:docker 권장.
#        절대 git 에 커밋하지 말 것.

# ─── 이미지 태그 (CI 가 git SHA 로 push 하면 그 태그를 지정) ───
# 비워두면 :latest 사용. 운영에서는 SHA 태그 박는 것을 권장 (롤백 용이).
API_IMAGE=<ECR_REGISTRY>/pangchelin-api:<git-sha>
WEB_IMAGE=<ECR_REGISTRY>/pangchelin-web:<git-sha>

# ─── DB (RDS) ───
DATABASE_URL=postgresql://<user>:<password>@<rds-endpoint>:5432/pangchelin?schema=public

# ─── 인증 ───
# 32 자 이상 랜덤 문자열. 한 번 정하면 변경 시 모든 토큰 무효화됨.
JWT_SECRET=replace-me-with-strong-random-string-of-32-or-more-chars

# ─── AWS (S3 업로드 IAM 사용자) ───
AWS_REGION=ap-northeast-2
AWS_S3_BUCKET=pangchelin-images-prod
AWS_ACCESS_KEY_ID=<iam-key>
AWS_SECRET_ACCESS_KEY=<iam-secret>

# ─── CORS ───
# 프론트엔드 도메인 (CloudFront 또는 직접 도메인)
CORS_ORIGIN=https://pangchelin.app
