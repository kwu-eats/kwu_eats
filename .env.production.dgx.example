# 팡슐랭 운영 환경 변수 템플릿 (DGX STATION 임시 운영)
#
# 사용법: 이 파일을 복사해 DGX STATION 의 프로젝트 디렉토리에
#        .env.production 으로 두고 실제 값을 채운다.
#        절대 git 에 커밋하지 말 것.
#
# AWS 시나리오는 .env.production.example 참고.
# 두 시나리오를 오갈 때는 이 파일과 AWS 용 파일을 백업해두고 교체만 하면 됨.

# ─── 이미지 태그 (DGX 에서 직접 빌드) ───
API_IMAGE=pangchelin-api:local
WEB_IMAGE=pangchelin-web:local

# ─── Nginx 외부 노출 호스트 포트 ───
# DGX: 호스트 6006 = 외부 20320 (NAT). 다른 외부 포트가 필요하면
# 6007(20321) ~ 6015(20329) 범위 안에서 변경.
NGINX_HOST_PORT=6006

# ─── DB (자체 호스팅 PostgreSQL 컨테이너) ───
POSTGRES_USER=pangchelin
POSTGRES_PASSWORD=replace-me-with-strong-random-32-or-more-chars
POSTGRES_DB=pangchelin
# api 컨테이너에서 본 DSN. 호스트는 docker network 의 서비스명 'postgres'.
DATABASE_URL=postgresql://pangchelin:replace-me-with-strong-random-32-or-more-chars@postgres:5432/pangchelin?schema=public

# ─── 인증 ───
# 32 자 이상 랜덤 문자열. 한 번 정하면 변경 시 모든 토큰 무효화됨.
JWT_SECRET=replace-me-with-strong-random-string-of-32-or-more-chars

# ─── 자체 호스팅 MinIO (S3 호환) ───
MINIO_ROOT_USER=pangchelin-admin
MINIO_ROOT_PASSWORD=replace-me-with-strong-random-20-or-more-chars

# ─── S3 호환 키 (api 가 MinIO 와 통신) ───
# api 컨테이너에서 본 endpoint. 호스트는 docker network 의 서비스명 'minio'.
S3_ENDPOINT=http://minio:9000
S3_REGION=us-east-1
S3_ACCESS_KEY=pangchelin-admin
S3_SECRET_KEY=replace-me-with-strong-random-20-or-more-chars
S3_BUCKET=pangchelin
S3_FORCE_PATH_STYLE=true

# ─── 공개 이미지 URL 베이스 ───
# Nginx 가 /uploads/* 를 MinIO 로 reverse proxy → 상대경로 사용.
# 도메인/IP 무관 → DGX IP 바뀌거나 AWS 복귀해도 DB 값에 영향 없음.
PUBLIC_IMAGE_BASE_URL=/uploads

# ─── AWS 키는 비워둠 (S3_* 가 우선) ───
AWS_REGION=
AWS_S3_BUCKET=
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=

# ─── CORS ───
# DGX STATION 의 외부 접속 URL. 외부 포트 20320 사용.
CORS_ORIGIN=http://<dgx-host-or-ip>:20320
